{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/languages/python/schemas/python-semantic-capabilities.v1.schema.json",
  "title": "Python Semantic Capabilities",
  "description": "Python provider-specific capability vocabulary for semantic-language registry method descriptors.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "schemaVersion", "languageId", "providerId"],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.languages.python.py-harness.capabilities"
    },
    "schemaVersion": {
      "const": "1"
    },
    "languageId": {
      "const": "python"
    },
    "providerId": {
      "const": "py-harness"
    },
    "capability": {
      "$ref": "#/$defs/capabilityDescriptor"
    },
    "ingestSurface": {
      "$ref": "#/$defs/ingestSurfaceDescriptor"
    }
  },
  "$defs": {
    "namespace": {
      "enum": ["semantic", "python"]
    },
    "capabilityDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["languageId", "namespace", "name"],
      "properties": {
        "languageId": {
          "const": "python"
        },
        "namespace": {
          "$ref": "#/$defs/namespace"
        },
        "name": {
          "enum": [
            "workspace-router",
            "python-package-root-search",
            "package-prime-map",
            "python-reasoning-tree-prime",
            "python-entry-point-search",
            "reasoning-owner-search",
            "parser-visible-module-owner-search",
            "pytest-test-owner-search",
            "path-owner-fallback",
            "dependency-manifest-search",
            "dependency-local-usage-search",
            "dependency-version-scope",
            "dependency-api-token-usage-search",
            "exported-api-shape-search",
            "public-function-api-shape-search",
            "public-data-api-shape-search",
            "public-external-type-search",
            "public-api-type-text-search",
            "symbol-definition-search",
            "owner-callsite-search",
            "import-edge-search",
            "owner-path-text-search",
            "export-text-search",
            "parser-visible-source-text-search",
            "external-candidate-ingest",
            "stdin-shape-detection",
            "owner-grouped-ingest"
          ]
        }
      }
    },
    "ingestSurfaceDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["languageId", "namespace", "name"],
      "properties": {
        "languageId": {
          "const": "python"
        },
        "namespace": {
          "$ref": "#/$defs/namespace"
        },
        "name": {
          "enum": [
            "non-parser-path",
            "non-parser-text",
            "docs-text",
            "external-api-docs",
            "schema-json",
            "generated-artifact"
          ]
        }
      }
    }
  }
}
