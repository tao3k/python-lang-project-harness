[tree] $TEMP python
[project]
- name=snapshot-package requires-python=>=3.12
- import-names=pkg
- package-roots=$TEMP/src/pkg
- scripts=snapshot-cli
- entry-points=pytest11:snapshot
[nodes]
  - pkg.domain (package; doc; public; children=models,service; exports=build) $TEMP/src/pkg/domain/__init__.py
    - pkg.domain.models (module; doc; public; exports=Model,build) $TEMP/src/pkg/domain/models.py
    - pkg.domain.service (module; doc; public; exports=build) $TEMP/src/pkg/domain/service.py
[imports]
- pkg.domain -> pkg.domain.service (relative; module; as build)
- pkg.domain.models -> pkg.domain.service (relative; module; as build)
